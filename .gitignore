# ============================================================
# Unity 6 (6000.3.x) — Elyqara_3D
# Base: github/gitignore/Unity.gitignore (April 2026)
# CRITICAL: NEVER add *.meta — meta files store GUIDs that link
#           assets. Losing them silently corrupts prefabs across
#           machines.
# ============================================================

# Unity-generated
/[Ll]ibrary/
/[Tt]emp/
/[Oo]bj/
/[Bb]uild/
/[Bb]uilds/
/[Ll]ogs/
/[Uu]ser[Ss]ettings/
/[Mm]emoryCaptures/
/[Rr]ecordings/
/.utmp/

# Asset Store / vendor editor folders
/[Aa]ssets/AssetStoreTools*
/[Aa]ssets/Plugins/Editor/JetBrains*

# Visual Studio / Rider / VS Code
.vs/
.vscode/
.idea/
*.csproj
*.unityproj
*.sln
*.suo
*.tmp
*.user
*.userprefs
*.pidb
*.booproj
*.svd
*.pdb
*.mdb
*.opendb
*.VC.db

# Unity build artifacts
sysinfo.txt
*.apk
*.aab
*.unitypackage
*.app
crashlytics-build.properties

# OS
.DS_Store
Thumbs.db
ehthumbs.db
Desktop.ini

# Steamworks dev artifacts
steam_api*.log
steam_appid.txt.bak

# ============================================================
# Claude Code — keep CLAUDE.md and .claude/settings.json tracked
# (project policy), ignore per-machine overrides and caches.
# ============================================================
.claude/settings.local.json
.claude/cache/
.claude/transcripts/
.claude/.last-session

# Secrets
*.env
.env.*
secrets/
**/credentials.json

# Allow legacy CLAUDE.md to stay tracked — it's intentional history
# CLAUDE.md.legacy-* is kept (do not ignore)
